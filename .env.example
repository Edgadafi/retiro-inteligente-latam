# ── Coinbase CDP AgentKit ──────────────────────────────────────
CDP_API_KEY_NAME=
CDP_API_KEY_PRIVATE_KEY=
NETWORK_ID=arbitrum-sepolia
AGENT_WALLET_DATA_PATH=./data/agent-wallet.json

# Clave maestra para cifrar wallet en disco (AES-256-GCM).
# Producción: obligatoria — idealmente desde KMS/HSM, nunca en git.
# Generar: openssl rand -hex 32
WALLET_MASTER_KEY=

# ── Supabase (estado de depósitos SPEI) ────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Contraseña de Database (Settings → Database) — solo para npm run db:apply-schema
SUPABASE_DB_PASSWORD=

# Settlement SPEI → MXNB (backoff exponencial)
SETTLEMENT_MAX_ATTEMPTS=10
SETTLEMENT_BASE_DELAY_MS=2000
SETTLEMENT_MAX_DELAY_MS=120000
SETTLEMENT_RECONCILE_INTERVAL_MS=60000
# full = máxima dispersión anti thundering herd | equal | none
SETTLEMENT_JITTER_STRATEGY=full

# ── Juno / Bitso Business ────────────────────────────────────────
JUNO_API_BASE_URL=https://stage.buildwithjuno.com
JUNO_API_KEY=
BITSO_WEBHOOK_SECRET=

# ── Etherfuse Stablebonds ────────────────────────────────────────
ETHERFUSE_API_BASE_URL=https://api.etherfuse.com
ETHERFUSE_API_KEY=

# ── Arbitrum RPC ─────────────────────────────────────────────────
ARBITRUM_SEPOLIA_RPC_URL=
ARBITRUM_ONE_RPC_URL=

# ── Server ───────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ── OpenAI (MCP / Agente conversacional) ───────────────────────
OPENAI_API_KEY=

# true = simula mint MXNB + CETES sin CDP (auto si faltan credenciales CDP)
ONCHAIN_SANDBOX_MODE=true
